generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenants       Tenant[]
  sessions      Session[]
  accounts      Account[]

  @@map("ps_user")
  @@schema("public")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ps_session")
  @@schema("public")
}

model Account {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String
  accountId  String
  password   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([providerId, accountId])
  @@map("ps_account")
  @@schema("public")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ps_verification")
  @@schema("public")
}

model Tenant {
  id            String         @id @default(uuid())
  slug          String         @unique
  displayName   String
  bio           String?
  avatarUrl     String?
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cases         PromptCase[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("ps_tenant")
  @@schema("public")
}

model PromptCase {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title          String
  slug           String
  category       String   @default("photography")
  tags           String[] @default([])
  emoji          String   @default("📷")
  coverImageUrl  String
  images         String[]
  promptText     String
  sourcePlatform String?
  sourceAuthor   String?
  // Multi-modal preview: image (default), video, or web
  previewType    String?  @default("image")
  previewSource  String?
  previewPoster  String?
  published      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, slug])
  @@map("ps_prompt_case")
  @@schema("public")
}

model Subscription {
  id                    String    @id @default(uuid())
  userId                String
  tenantId              String
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stripeSessionId       String    @unique
  stripeSubscriptionId  String?   @unique
  stripeCustomerId      String?
  status                String    @default("active")
  plan                  String    @default("monthly")
  createdAt             DateTime  @default(now())
  expiresAt             DateTime?

  @@index([userId, tenantId])
  @@map("ps_subscription")
  @@schema("public")
}
